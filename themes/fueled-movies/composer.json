{
	"name": "10up/tenup-theme",
	"description": "A block-based WordPress theme for the Fueled Movies training project.",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-theme",
	"authors": [
		{
			"name": "10up",
			"email": "info@10up.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"10up/wp-framework": "~1.3.1"
	},
	"require-dev": {
		"10up/phpcs-composer": "dev-trunk"
	},
	"scripts": {
		"lint": "phpcs .",
		"lint-fix": "phpcbf ."
	},
	"autoload": {
		"psr-4": {
			"TenupBlockTheme\\": "src/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
