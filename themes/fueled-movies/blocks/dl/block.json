{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tenup/dl",
	"title": "Description List",
	"description": "A semantic description list element used commonly for product specs, contact info, and FAQ-style content.",
	"category": "text",
	"keywords": [
		"description",
		"definition",
		"list",
		"dl",
		"dt",
		"dd",
		"terms"
	],
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"link": true,
			"text": true
		},
		"html": false,
		"interactivity": {
			"clientNavigation": true
		},
		"layout": {
			"allowSwitching": true,
			"default": {
				"orientation": "vertical",
				"type": "flex"
			}
		},
		"reusable": true,
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true
		},
		"typography": {
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true,
			"fontSize": true,
			"lineHeight": true
		}
	},
	"render": "file:./markup.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
