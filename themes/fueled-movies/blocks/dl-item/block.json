{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tenup/dl-item",
	"title": "Description List Item",
	"description": "A term and description pair within a description list.",
	"category": "text",
	"keywords": ["description", "definition", "term", "dt", "dd"],
	"parent": ["tenup/dl"],
	"supports": {
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"align": ["wide", "full"],
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"text": true
		},
		"html": false,
		"interactivity": {
			"clientNavigation": true
		},
		"layout": {
			"allowSizingOnChildren": true,
			"allowSwitching": true,
			"default": {
				"orientation": "vertical",
				"type": "flex"
			}
		},
		"reusable": false,
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
