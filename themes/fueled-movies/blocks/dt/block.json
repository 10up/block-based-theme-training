{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tenup/dt",
	"title": "Description List Term",
	"description": "The term (dt) within a description list item.",
	"category": "text",
	"keywords": ["term", "dt", "definition", "label"],
	"parent": ["tenup/dl-item"],
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"link": true,
			"text": true
		},
		"html": false,
		"interactivity": {
			"clientNavigation": true
		},
		"lock": false,
		"reusable": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true,
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"content": {
			"default": "",
			"role": "content",
			"type": "string"
		},
		"lock": {
			"default": {
				"move": true,
				"remove": true
			},
			"type": "object"
		}
	},
	"render": "file:./markup.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
