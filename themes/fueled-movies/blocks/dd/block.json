{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tenup/dd",
	"title": "Description List Description",
	"description": "The description (dd) within a description list item.",
	"category": "text",
	"keywords": ["description", "dd", "definition", "value"],
	"parent": ["tenup/dl-item"],
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"link": true,
			"text": true
		},
		"html": false,
		"interactivity": {
			"clientNavigation": true
		},
		"layout": {
			"allowSizingOnChildren": true,
			"default": {
				"type": "default"
			}
		},
		"reusable": false,
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true
		},
		"typography": {
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true,
			"fontSize": true,
			"lineHeight": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css"
}
