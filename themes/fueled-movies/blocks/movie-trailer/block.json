{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tenup/movie-trailer",
	"title": "Movie Trailer",
	"description": "IMDB trailer embed for the current movie, with a placeholder image fallback when no trailer ID is set.",
	"category": "theme",
	"keywords": [
		"trailer",
		"movie",
		"video"
	],
	"textdomain": "tenup-block-theme",
	"attributes": {},
	"supports": {
		"interactivity": {
			"clientNavigation": true
		}
	},
	"usesContext": [
		"postId",
		"postType"
	],
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
